{
  "manifest_version": 3,
  "name": "ChronoRead Summarizer",
  "version": "1.0",
  "description": "Get an article summary based on the time you have available.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}